{
  "name": "backend-companies",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/backend/companies/src",
  "projectType": "library",
  "tags": ["scope:backend", "type:feature", "platform:node"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/backend/companies",
        "main": "libs/backend/companies/src/index.ts",
        "tsConfig": "libs/backend/companies/tsconfig.lib.json",
        "assets": ["libs/backend/companies/*.md"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/backend/companies/jest.config.cts"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "cache": true,
      "outputs": [],
      "options": {
        "command": "tsc --noEmit -p libs/backend/companies/tsconfig.lib.json"
      }
    }
  }
}
