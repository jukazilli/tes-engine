{
    "name":  "frontend-ui",
    "$schema":  "../../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot":  "libs/frontend/ui/src",
    "projectType":  "library",
    "tags":  [
                 "scope:frontend",
                 "type:ui"
             ],
    "targets":  {
                    "build":  {
                                  "executor":  "@nx/js:tsc",
                                  "outputs":  [
                                                  "{options.outputPath}"
                                              ],
                                  "options":  {
                                                  "outputPath":  "dist/libs/frontend/ui",
                                                  "main":  "libs/frontend/ui/src/index.ts",
                                                  "tsConfig":  "libs/frontend/ui/tsconfig.lib.json",
                                                  "assets":  [
                                                                 "libs/frontend/ui/*.md"
                                                             ]
                                              }
                              },
                    "test":  {
                                 "executor":  "@nx/jest:jest",
                                 "outputs":  [
                                                 "{workspaceRoot}/coverage/{projectRoot}"
                                             ],
                                 "options":  {
                                                 "jestConfig":  "libs/frontend/ui/jest.config.cts"
                                             }
                             }
                }
}
