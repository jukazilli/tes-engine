{
  "name": "engine-core",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/engines/core/src",
  "projectType": "library",
  "tags": ["scope:engine", "type:domain", "platform:agnostic"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/engines/core",
        "main": "libs/engines/core/src/index.ts",
        "tsConfig": "libs/engines/core/tsconfig.lib.json",
        "assets": ["libs/engines/core/*.md"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/engines/core/jest.config.cts"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "cache": true,
      "outputs": [],
      "options": {
        "command": "tsc --noEmit -p libs/engines/core/tsconfig.lib.json"
      }
    }
  }
}
