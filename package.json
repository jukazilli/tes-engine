{
  "name": "@tes-engine/source",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@9.11.0",
  "engines": {
    "node": ">=22.12.0 <23",
    "pnpm": ">=9.11.0 <10"
  },
  "scripts": {
    "dev:web": "nx serve web",
    "dev:api": "nx serve api",
    "dev:worker": "nx serve worker",
    "build": "nx run-many -t build",
    "build:web": "nx build web",
    "build:api": "nx build api",
    "build:worker": "nx build worker",
    "lint": "nx run-many -t eslint:lint lint",
    "test": "nx run-many -t test",
    "test:api": "nx test api",
    "test:auth": "nx test api --testPathPatterns=auth",
    "test:email": "nx test api --testPathPatterns=email",
    "test:organizations": "nx test api --testPathPatterns=organizations",
    "test:rbac": "nx test api --testPathPatterns=rbac",
    "test:invitations": "nx test api --testPathPatterns=invitations",
    "test:tenant-authorization": "nx test api --testPathPatterns=tenant-authorization",
    "test:db": "node tools/database/test-db.mjs",
    "test:db:integration": "node tools/database/test-db.mjs",
    "test:db:rls": "node tools/database/test-db-rls.mjs",
    "typecheck": "nx run-many -t typecheck --all",
    "typecheck:coverage": "node tools/quality/validate-typecheck-coverage.mjs",
    "affected:lint": "nx affected -t eslint:lint lint",
    "affected:test": "nx affected -t test",
    "graph": "nx graph",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "docs:lint": "markdownlint-cli2",
    "docs:links": "node tools/docs/validate-docs.mjs",
    "docs:validate": "pnpm docs:lint && pnpm docs:links",
    "architecture:validate": "node tools/architecture/validate-project-tags.mjs",
    "architecture:boundaries": "node tools/architecture/validate-boundary-fixtures.mjs",
    "quality:format": "pnpm format:check",
    "quality:architecture": "pnpm architecture:validate && pnpm architecture:boundaries",
    "quality:typecheck": "pnpm typecheck:coverage && pnpm typecheck",
    "quality:lint": "pnpm lint",
    "quality:test": "pnpm test",
    "openapi:validate": "pnpm build:api && node tools/openapi/validate-openapi.mjs",
    "db:bootstrap": "node tools/database/bootstrap-runtime-role.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node tools/database/migrate.mjs",
    "db:check": "node tools/database/check.mjs",
    "db:validate": "node tools/database/validate.mjs",
    "db:status": "node tools/database/status.mjs",
    "auth:cleanup": "node tools/auth/cleanup.mjs",
    "quality:database": "pnpm db:check && pnpm db:validate && pnpm test:db && pnpm test:db:rls",
    "quality:build": "pnpm build && pnpm openapi:validate",
    "quality:docs": "pnpm docs:validate",
    "quality:fast": "pnpm quality:format && pnpm quality:docs && pnpm quality:architecture && pnpm quality:typecheck && pnpm quality:lint",
    "quality": "pnpm quality:fast && pnpm quality:database && pnpm quality:test && pnpm quality:build",
    "ci": "pnpm quality",
    "quality:ci": "pnpm install --frozen-lockfile && pnpm quality",
    "ci:validate": "node tools/ci/validate-workflows.mjs",
    "prepare": "husky",
    "staged:check": "lint-staged",
    "commitlint": "commitlint",
    "commitlint:last": "commitlint --from HEAD~1 --to HEAD --verbose",
    "infra:up": "powershell -ExecutionPolicy Bypass -File infrastructure/scripts/infra-up.ps1",
    "infra:down": "powershell -ExecutionPolicy Bypass -File infrastructure/scripts/infra-down.ps1",
    "infra:status": "powershell -ExecutionPolicy Bypass -File infrastructure/scripts/infra-status.ps1",
    "infra:logs": "powershell -ExecutionPolicy Bypass -File infrastructure/scripts/infra-logs.ps1",
    "infra:validate": "powershell -ExecutionPolicy Bypass -File infrastructure/scripts/infra-validate.ps1"
  },
  "private": true,
  "devDependencies": {
    "@angular-devkit/core": "~21.2.0",
    "@angular-devkit/schematics": "~21.2.0",
    "@angular/build": "~21.2.0",
    "@angular/cli": "~21.2.0",
    "@angular/compiler-cli": "~21.2.0",
    "@angular/language-service": "~21.2.0",
    "@commitlint/cli": "21.1.0",
    "@commitlint/config-conventional": "21.1.0",
    "@eslint/js": "^9.8.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/angular": "23.0.1",
    "@nx/eslint": "23.0.1",
    "@nx/eslint-plugin": "23.0.1",
    "@nx/jest": "23.0.1",
    "@nx/js": "23.0.1",
    "@nx/nest": "23.0.1",
    "@nx/node": "23.0.1",
    "@nx/vite": "23.0.1",
    "@nx/web": "23.0.1",
    "@nx/webpack": "23.0.1",
    "@nx/workspace": "23.0.1",
    "@schematics/angular": "~21.2.0",
    "@swc/helpers": "~0.5.18",
    "@types/jest": "~30.0.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "8.20.0",
    "@types/supertest": "6.0.3",
    "@typescript-eslint/utils": "^8.40.0",
    "angular-eslint": "^21.2.0",
    "drizzle-kit": "0.31.10",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "husky": "9.1.7",
    "jest": "~30.3.0",
    "jest-environment-jsdom": "~30.3.0",
    "jest-environment-node": "~30.3.0",
    "jest-preset-angular": "~16.0.0",
    "jest-util": "~30.3.0",
    "jsonc-eslint-parser": "^2.1.0",
    "lint-staged": "17.0.8",
    "markdownlint-cli2": "0.22.1",
    "nx": "23.0.1",
    "prettier": "~3.6.2",
    "supertest": "7.1.4",
    "ts-jest": "^29.4.0",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "webpack": "^5.101.3",
    "webpack-cli": "^7.0.0",
    "webpack-dev-server": "^5.2.1",
    "yaml": "2.9.0"
  },
  "dependencies": {
    "@angular/animations": "21.2.17",
    "@angular/cdk": "21.2.4",
    "@angular/common": "~21.2.0",
    "@angular/compiler": "~21.2.0",
    "@angular/core": "~21.2.0",
    "@angular/forms": "~21.2.0",
    "@angular/platform-browser": "~21.2.0",
    "@angular/platform-browser-dynamic": "~21.2.0",
    "@angular/router": "~21.2.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@po-ui/ng-components": "21.21.0",
    "@po-ui/style": "21.21.0",
    "argon2": "^0.44.0",
    "axios": "^1.6.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "drizzle-orm": "0.45.2",
    "helmet": "^8.2.0",
    "joi": "^18.2.3",
    "nestjs-pino": "^4.6.1",
    "nodemailer": "^9.0.1",
    "pg": "8.22.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.0",
    "resend": "^6.14.0",
    "rxjs": "~7.8.0",
    "zone.js": "0.15.1"
  }
}
