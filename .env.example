NODE_ENV=development

API_PORT=3000
API_PREFIX=api
WEB_API_URL=http://localhost:3000/api
LOG_LEVEL=debug
CORS_ORIGINS=http://localhost:4200,http://localhost:4300
APP_VERSION=0.1.0
OPENAPI_ENABLED=true

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=15432
POSTGRES_DB=tes_engine
POSTGRES_USER=tes_engine
